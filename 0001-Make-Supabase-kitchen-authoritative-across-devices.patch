+    function friendlyAuthError(error, action) {
+      const message = String(error?.message || "");
+      const code = String(error?.code || "");
+      if (code === "over_email_send_rate_limit" || /email rate limit/i.test(message)) {
+        return action === "reset"
+          ? "Supabase has temporarily limited password-reset emails. Do not keep clicking it. Wait before requesting another email; the most recent reset email you received is still the one to use."
+          : "Supabase has temporarily limited account emails. If this account already exists, choose Log In instead of Start Free Trial. Otherwise, wait before requesting another email.";
+      }
+      if (code === "invalid_credentials" || /invalid login credentials/i.test(message)) {
+        return "That email and password do not match. Use Forgot password once if you need to set a new password.";
+      }
+      if (/already registered|already exists/i.test(message)) {
+        return "That account already exists. Choose Log In instead of creating another trial account.";
+      }
+      return message || "The account request could not be completed.";
+    }
+
     function renderMode() {
