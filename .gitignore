# ---------------------------------------------------------
.vscode/
.idea/

# ---------------------------------------------------------
# Python virtual environments
# ---------------------------------------------------------
.venv/
venv/
env/

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
*.log
test-results/release-gate-report.json

# ---------------------------------------------------------
